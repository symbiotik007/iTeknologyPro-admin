# Supabase (públicas — se incrustan en el cliente)
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key

# Supabase Service Role (SECRETA — solo servidor, salta RLS, NUNCA con prefijo NEXT_PUBLIC_)
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key

# URL del storefront en producción (en local: http://localhost:3002)
NEXT_PUBLIC_STORE_URL=https://tu-tienda.vercel.app

# Mapbox (pública)
NEXT_PUBLIC_MAPBOX_TOKEN=pk.tu-mapbox-token
